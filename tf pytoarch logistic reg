import numpy as np
import tensorflow as tf
from tensorflow.keras import layers

x = np.array([
    [5, 60, 50],
    [6, 65, 55],
    [7, 70, 60],
    [8, 80, 70]
])

y = np.array([0, 0, 1, 1])

max_vals = np.max(x, axis=0)
x = x / max_vals

model = tf.keras.Sequential([
    tf.keras.Input(shape=(3,)),
    layers.Dense(1, activation='sigmoid')
])

model.compile(
    optimizer='sgd',
    loss='binary_crossentropy',
    metrics=['accuracy']
)

model.fit(x, y, epochs=1000, verbose=0)

X = []
for i in range(4):
    print(f"\nStudent {i+1}")
    study = float(input("Enter study hours: "))
    attend = float(input("Enter attendance: "))
    assign = float(input("Enter assignment score: "))
    X.append([study, attend, assign])

X = np.array(X)
X = X / max_vals

predictions = model.predict(X)

print("\n------ Result ------")

for i in range(4):
    prob = predictions[i][0]
    result = "PASS" if prob >= 0.5 else "FAIL"

    print(f"\nStudent {i+1}:")
    print(f"Study Hours: {X[i][0] * max_vals[0]}")
    print(f"Attendance: {X[i][1] * max_vals[1]}")
    print(f"Assignment Score: {X[i][2] * max_vals[2]}")
    print(f"Prediction: {result}")
    print(f"Confidence: {prob:.2f}")

